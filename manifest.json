{
  "manifest_version": 3,
  "name": "Mindful Site Timer",
  "description": "Set daily limits for distracting sites and pause before continuing.",
  "version": "1.0.0",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Mindful Site Timer",
    "default_popup": "popup.html"
  }
}